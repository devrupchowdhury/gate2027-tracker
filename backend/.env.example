PORT=3001
NODE_ENV=development

# PostgreSQL connection string
# Render auto-injects this in production
# For local dev, use: postgresql://localhost/gate_agent
DATABASE_URL=postgresql://localhost/gate_agent

# Clerk — https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Anthropic — https://console.anthropic.com
# The agent uses claude-opus-4-5 for agentic reasoning
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Your deployed Vercel frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app
